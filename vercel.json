{
  "version": 2,
  "builds": [
    {
      "src": "main.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/main.js" },
    { "src": "/bridge.js", "dest": "/public/bridge.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
